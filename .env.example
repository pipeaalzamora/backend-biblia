# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db?appName=app

# Redis (opcional, para caché). Si lo dejas vacío usa caché en memoria.
REDIS_URL=

# Salt para hash de IPs (seguridad)
IP_SALT=tu_salt_aleatorio_aqui

# Frontend URL (para CORS)
FRONTEND_URL=https://tu-app.com

# Puerto (Render lo asigna automáticamente)
PORT=3000
